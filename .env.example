MODE=local
PORT=3000

# Provider selection: openai | anthropic | cohere | huggingface | gemini
LLM_PROVIDER=openai

# Global request behavior
LLM_TIMEOUT_MS=15000
LLM_MAX_RETRIES=1
LLM_BREAKER_FAILURE_THRESHOLD=3
LLM_BREAKER_COOLDOWN_MS=30000

# OpenAI (or OpenAI-compatible endpoints)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_VERSION=2023-06-01

# Cohere
COHERE_API_KEY=
COHERE_API_URL=https://api.cohere.ai/generate
COHERE_MODEL=command

# Hugging Face
HUGGINGFACE_API_KEY=
HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models/
HUGGINGFACE_MODEL=

# Gemini
GEMINI_API_KEY=
GEMINI_API_URL=
GEMINI_MODEL=gemini-1.5-flash

# Optional: set agents and per-agent provider map
AGENTS=Gemini,Claude,GPT
# JSON or CSV: {"Gemini":"openai","Claude":"anthropic","GPT":"openai"}
AGENT_PROVIDER_MAP=Gemini:openai,Claude:anthropic,GPT:openai

DECIDER_AGENT=GPT

